{
  "compilerOptions": {
    "target": "ESNext",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "module": "esnext",
    // "noEmit": false,                      // ⛳ ВАЖНО: разрешить генерацию .js
    // "outDir": ".next/server",             // Куда класть .js
    // "module": "commonjs",                 // Для совместимости с TypeORM
    "moduleResolution": "node", // Вместо bundler
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "db/models/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}