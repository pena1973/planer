{
    "version": "0.2.0",
    "configurations": [
        // {
        //     "name": "Launch Edge",
        //     "request": "launch",
        //     "type": "msedge",
        //     "url": "http://localhost:3000",
        //     "webRoot": "${workspaceFolder}"
        // },

        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Chrome against localhost",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}"
        },
        {
            "name": "Next.js: Node.js",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "node",
            "runtimeArgs": [
                "--inspect-brk",
                "./node_modules/.bin/next",
                "dev"
            ],
            "skipFiles": [
                "<node_internals>/**"
            ],
            "console": "integratedTerminal",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\b(http|https)://[a-zA-Z0-9.-]+(:[0-9]+)?\\b"
            }
        }
    ]
}
