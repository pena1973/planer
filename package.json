{
  "name": "planer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "tsc -p tsconfig.models.json",
    "build": "npm run prebuild && next build",
    "start": "cross-env NODE_ENV=production next start",
    "lint": "next lint",
    "trans": "i18next -c i18next-parser.config.ts --fail-on-warnings",
    "migration:create": "powershell -Command \"$date = Get-Date -Format 'yyyy-MM-dd'; npx typeorm-ts-node-esm migration:create pages/db/migrations/Migration-$date\"",
    "migration:generate": "npx ts-node -r tsconfig-paths/register node_modules/typeorm/cli.js migration:generate pages/db/migrations/Migration -d pages/db/ormconfig.ts"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.1.0",
    "@types/jsonwebtoken": "^9.0.9",
    "eslint": "^8.57.1",
    "i18next-browser-languagedetector": "^8.0.2",
    "i18next-http-backend": "^3.0.1",
    "i18next-resources-to-backend": "^1.2.1",
    "jsonwebtoken": "^9.0.2",
    "next": "^14.2.20",
    "node-fetch": "^3.3.2",
    "pg": "^8.13.1",
    "react": "^18",
    "react-dom": "^18",
    "react-draggable": "^4.4.6",
    "react-redux": "^9.1.2",
    "redux": "^5.0.1",
    "redux-persist": "^6.0.0",
    "reflect-metadata": "^0.2.2",
    "sass": "^1.81.0",
    "sharp": "^0.34.2",
    "tsconfig-paths": "^4.2.0",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/react-i18next": "^8.1.0",
    "@types/react-window": "^1.8.8",
    "@types/reflect-metadata": "^0.1.0",
    "cross-env": "^7.0.3",
    "eslint-config-next": "14.2.14",
    "i18next": "^24.2.0",
    "i18next-parser": "^9.0.2",
    "react-i18next": "^15.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
