{
  "name": "planer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "tsc -p tsconfig.models.json",
    "build": "npm run prebuild && next build",
    "start": "next start",
    "lint": "next lint",
    "trans": "i18next -c i18next-parser.config.ts --fail-on-warnings",
    "typeorm": "cross-env TS_NODE_PROJECT=tsconfig.server.json ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d db/cli-data-source.ts",
    "migration:create": "powershell -Command \"$ts=(Get-Date).ToString('yyyyMMddHHmmss'); npm run typeorm -- migration:create ./db/migrations/Mig_$ts\"",
    "migration:generate": "powershell -Command \"$ts=(Get-Date).ToString('yyyyMMddHHmmss'); npm run typeorm -- migration:generate ./db/migrations/Mig_$ts\"",
    "migration:create:bash": "npm run typeorm -- migration:create ./db/migrations/$(date +%Y%m%d%H%M%S)",
    "migration:generate:bash": "npm run typeorm -- migration:generate ./db/migrations/$(date +%Y%m%d%H%M%S)",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "build:orm": "tsc -p tsconfig.server.json",
    "migration:run:prod": "node ./node_modules/typeorm/cli.js -d dist/db/cli-data-source.js migration:run",
    "clean": "rimraf .next node_modules package-lock.json"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.3.0",
    "@reduxjs/toolkit": "^2.1.0",
    "@sendgrid/mail": "^8.1.5",
    "@stripe/stripe-js": "^7.9.0",
    "@types/jsonwebtoken": "^9.0.9",
    "cross-env": "10.0.0",
    "eslint": "^8.57.1",
    "framer-motion": "^12.23.24",
    "i18next-browser-languagedetector": "^8.0.2",
    "i18next-http-backend": "^3.0.1",
    "i18next-resources-to-backend": "^1.2.1",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.548.0",
    "micro": "^10.0.1",
    "next": "^14.2.20",
    "node-fetch": "^3.3.2",
    "nodemailer": "^7.0.6",
    "pg": "^8.13.1",
    "react": "^18",
    "react-dom": "^18",
    "react-draggable": "^4.4.6",
    "react-i18next": "^15.6.0",
    "react-redux": "^9.1.2",
    "redux": "^5.0.1",
    "redux-persist": "^6.0.0",
    "reflect-metadata": "^0.2.2",
    "sass": "^1.81.0",
    "sharp": "^0.34.2",
    "stripe": "^18.5.0",
    "tsconfig-paths": "^4.2.0",
    "typeorm": "^0.3.20",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@types/node": "^20.19.11",
    "@types/nodemailer": "^7.0.1",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/react-i18next": "^8.1.0",
    "@types/react-window": "^1.8.8",
    "@types/reflect-metadata": "^0.1.0",
    "eslint-config-next": "14.2.14",
    "i18next": "25.4.1",
    "i18next-parser": "^9.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
