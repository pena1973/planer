{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": ".",
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "sourceMap": false,
    "declaration": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    // Для TypeORM-энтити при сборке
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    // Чтобы не требовал инициализацию полей в классах-сущностях
    "strictPropertyInitialization": false
  },
  "include": [
    "db/**/*.ts",
    "db/**/*.d.ts", // ← чтобы подхватывать локальные декларации при необходимости
    "types/**/*.d.ts" // ← если держишь шимы тут
  ]
}