{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": ".",
    "module": "commonjs",
    "target": "ES2020",
    "sourceMap": false,
    "declaration": false,
    "esModuleInterop": true,
    "skipLibCheck": true,

    // Для TypeORM-энтити при сборке
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    // Чтобы не требовал инициализацию полей в классах-сущностях
    "strictPropertyInitialization": false
  },
  "include": ["db/**/*.ts"]
}


