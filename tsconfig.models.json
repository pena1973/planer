{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "build",
    "rootDir": ".",
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2019",
    "noEmit": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "sourceMap": false
  },
  "include": [
    "db/models/**/*"
  ]
}